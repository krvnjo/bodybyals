---
import Layout from "../layouts/Layout.astro";
import { Dumbbell, UtensilsCrossed, Gift, ShieldCheck, UserCheck } from "@lucide/astro/icons/index";

const services = [
  {
    title: "Online Coaching & Nutrition Guide",
    icon: Dumbbell,
    features: [
      "Easy-to-follow workouts you can do anytime, anywhere — no gym required",
      "A sustainable nutrition guide — helps you pick the right foods and ingredients, know what to eat, when to eat, and what to avoid while still enjoying your favorite foods",
      "A complete program to help you get fit, healthy, and confident",
      "Chat support throughout the program",
      "Programs available: 3 months, 6 months, or 1 year Transformation Program",
    ],
    delay: null,
  },
  {
    title: "Meal Plan Service",
    icon: UtensilsCrossed,
    features: [
      "We focus on balancing hormones, not counting calories",
      "High-protein and low-carb meal plan",
      'Seed-oil free. Also known as the "Insulin Sensitivity Reset Diet"',
      "Features premium, high-quality ingredients like USDA Prime ribeye steak, fresh salmon, chicken, beef, eggs, and fresh salads",
      "Delivery within Metro Manila. Delivery fees apply depending on your location",
    ],
    delay: "0.2s",
  },
];
---

<Layout
  title="Services | BodyByAls"
  description="Transform your fitness journey with BodyByAls Online Coaching. Get easy-to-follow workouts, sustainable nutrition guidance, and hormone-based strategies from Coach Anton Soler. Train anywhere, eat smarter, and build lasting healthy habits.">
  <!-- Page Header Section Start -->
  <div class="page-header bg-section">
    <div class="container">
      <div class="row">
        <div class="col-lg-12">
          <!-- Page Header Box Start -->
          <div class="page-header-box">
            <h1 class="text-anime-style-3" data-cursor="-opaque">Our Services</h1>
            <nav class="wow fadeInUp">
              <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">home</a></li>
                <li class="breadcrumb-item active" aria-current="page">Services</li>
              </ol>
            </nav>
          </div>
          <!-- Page Header Box End -->
        </div>
      </div>
    </div>
  </div>
  <!-- Page Header Section End -->

  <!-- Page Services Start -->
  <div class="page-pricing">
    <div class="container">
      <div class="row">
        {
          services.map((service) => (
            <div class="col-xl-6 col-md-6">
              <div class="pricing-item wow fadeInUp" data-wow-delay={service.delay}>
                <div class="pricing-item-header">
                  <div class="pricing-item-header-box">
                    <div class="icon-box">
                      <service.icon color="#FFFFFF" stroke-width="1.5" />
                    </div>
                    <div class="pricing-item-content">
                      <h3>{service.title}</h3>
                    </div>
                  </div>
                </div>

                <div class="pricing-item-body">
                  <div class="pricing-item-list">
                    <h3>What's Included:</h3>
                    <ul>
                      {service.features.map((feature) => (
                        <li>{feature}</li>
                      ))}
                    </ul>
                  </div>

                  <div class="pricing-item-btn">
                    <a href="/#get-started" class="btn-default">
                      Get Started
                    </a>
                  </div>
                </div>
              </div>
            </div>
          ))
        }

        <div class="col-lg-12">
          <!-- Services Benefits List Start -->
          <div class="pricing-benefit-list wow fadeInUp" data-wow-delay="0.4s">
            <ul>
              <li><Gift size={24} color="var(--accent-color)" class="me-2" /> Free consultation available</li>
              <li><ShieldCheck size={24} color="var(--accent-color)" class="me-2" /> No hidden fees</li>
              <li><UserCheck size={24} color="var(--accent-color)" class="me-2" /> Personalized approach</li>
            </ul>
          </div>
          <!-- Services Benefits List End -->
        </div>
      </div>
    </div>
  </div>
  <!-- Page Services End -->
</Layout>

---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import { Gift, ShieldCheck, UserCheck } from "@lucide/astro/icons/index";
import { services } from "@/data/services";
---

<Layout
  title="Services | BodyByAls"
  description="Transform your fitness journey with BodyByAls Online Coaching. Get easy-to-follow workouts, sustainable nutrition guidance, and hormone-based strategies from Coach Anton Soler. Train anywhere, eat smarter, and build lasting healthy habits.">
  <PageHeader title="Our Services" breadcrumb="Services" />

  <!-- Page Services Start -->
  <div class="page-pricing">
    <div class="container">
      <div class="row">
        {
          services.map((service) => (
            <div class="col-xl-6 col-md-6">
              <div class="pricing-item wow fadeInUp" data-wow-delay={service.delay}>
                <div class="pricing-item-header">
                  <div class="pricing-item-header-box">
                    <div class="icon-box">
                      <service.icon color="#FFFFFF" stroke-width="1.5" />
                    </div>
                    <div class="pricing-item-content">
                      <h3>{service.title}</h3>
                    </div>
                  </div>
                </div>

                <div class="pricing-item-body">
                  <div class="pricing-item-list">
                    <h3>What's Included:</h3>
                    <ul>
                      {service.features.map((feature) => (
                        <li>{feature}</li>
                      ))}
                    </ul>
                  </div>

                  <div class="pricing-item-btn">
                    <a href="/#get-started" class="btn-default">
                      Get Started
                    </a>
                  </div>
                </div>
              </div>
            </div>
          ))
        }

        <div class="col-lg-12">
          <!-- Services Benefits List Start -->
          <div class="pricing-benefit-list wow fadeInUp" data-wow-delay="0.4s">
            <ul>
              <li><Gift size={24} color="var(--accent-color)" class="me-2" /> Free consultation available</li>
              <li><ShieldCheck size={24} color="var(--accent-color)" class="me-2" /> No hidden fees</li>
              <li><UserCheck size={24} color="var(--accent-color)" class="me-2" /> Personalized approach</li>
            </ul>
          </div>
          <!-- Services Benefits List End -->
        </div>
      </div>
    </div>
  </div>
  <!-- Page Services End -->
</Layout>

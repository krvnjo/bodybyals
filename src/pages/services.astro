---
import Layout from "../layouts/Layout.astro";
import { Dumbbell, Headset, LandPlot, MessagesSquare, Gift, ShieldCheck, UserCheck } from "@lucide/astro/icons/index";

const services = [
  {
    title: "Online Fitness Coaching",
    icon: Dumbbell,
    features: [
      "Easy-to-follow workout programs",
      "Proper form guidance",
      "Tailored to your lifestyle and goals",
      "Build confidence and stay consistent",
    ],
    delay: null,
  },
  {
    title: "Personalized Nutrition Plan",
    icon: LandPlot,
    features: [
      "Learn what and when to eat",
      "Know what to avoid",
      "Enjoy your favorite foods guilt-free",
      "Guided by Coach Anton",
    ],
    delay: "0.2s",
  },
  {
    title: "Chat Support",
    icon: MessagesSquare,
    features: [
      "Submit meal photos anytime",
      "Share your progress updates",
      "Get guidance every step of the way",
      "Direct access to your coach",
    ],
    delay: "0.4s",
  },
  {
    title: "Free Consultation",
    icon: Headset,
    features: [
      "Understand the program fully",
      "Get all your questions answered",
      "Goal assessment session",
      "No commitment required",
    ],
    delay: "0.6s",
  },
];
---

<Layout
  title="Services | BodyByAls"
  description="Transform your fitness journey with BodyByAls Online Coaching. Get easy-to-follow workouts, sustainable nutrition guidance, and hormone-based strategies from Coach Anton Soler. Train anywhere, eat smarter, and build lasting healthy habits.">
  <!-- Page Header Section Start -->
  <div class="page-header bg-section">
    <div class="container">
      <div class="row">
        <div class="col-lg-12">
          <!-- Page Header Box Start -->
          <div class="page-header-box">
            <h1 class="text-anime-style-3" data-cursor="-opaque">Our Services</h1>
            <nav class="wow fadeInUp">
              <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">home</a></li>
                <li class="breadcrumb-item active" aria-current="page">Services</li>
              </ol>
            </nav>
          </div>
          <!-- Page Header Box End -->
        </div>
      </div>
    </div>
  </div>
  <!-- Page Header Section End -->

  <!-- Page Services Start -->
  <div class="page-pricing">
    <div class="container">
      <div class="row">
        {
          services.map((service) => (
            <div class="col-xl-3 col-md-6">
              <div class="pricing-item wow fadeInUp" data-wow-delay={service.delay}>
                <div class="pricing-item-header">
                  <div class="pricing-item-header-box">
                    <div class="icon-box">
                      <service.icon color="#FFFFFF" stroke-width="1.5" />
                    </div>
                    <div class="pricing-item-content">
                      <h3>{service.title}</h3>
                    </div>
                  </div>
                </div>

                <div class="pricing-item-body">
                  <div class="pricing-item-list">
                    <h3>What's Included:</h3>
                    <ul>
                      {service.features.map((feature) => (
                        <li>{feature}</li>
                      ))}
                    </ul>
                  </div>

                  <div class="pricing-item-btn">
                    <a href="/#get-started" class="btn-default">
                      Get Started
                    </a>
                  </div>
                </div>
              </div>
            </div>
          ))
        }

        <div class="col-lg-12">
          <!-- Services Benefits List Start -->
          <div class="pricing-benefit-list wow fadeInUp" data-wow-delay="0.4s">
            <ul>
              <li><Gift size={24} color="var(--accent-color)" class="me-2" /> Free consultation available</li>
              <li><ShieldCheck size={24} color="var(--accent-color)" class="me-2" /> No hidden fees</li>
              <li><UserCheck size={24} color="var(--accent-color)" class="me-2" /> Personalized approach</li>
            </ul>
          </div>
          <!-- Services Benefits List End -->
        </div>
      </div>
    </div>
  </div>
  <!-- Page Services End -->
</Layout>

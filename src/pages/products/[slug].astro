---
import Layout from "../../layouts/Layout.astro";
import PageHeader from "../../components/PageHeader.astro";
import Lightbox from "../../components/Lightbox.astro";
import OrderLinks from "../../components/OrderLinks.astro";
import { Image, getImage } from "astro:assets";
import { products } from "@/data/products";

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;

// Pre-generate full-size WebP versions for the lightbox
const fullImages = await Promise.all(
  product.gallery.map((img) => getImage({ src: img, format: "webp", width: 1600 })),
);
const lightboxImageUrls = fullImages.map((i) => i.src);
---

<Layout
  title={`${product.title} | BodyByAls`}
  description={product.description}>
  <PageHeader title={product.title} breadcrumb={product.title} parent={{ label: "Products", href: "/products" }} />

  <!-- Page Product Gallery Start -->
  <div class="page-team">
    <div class="container">
      <OrderLinks />

      <div class="masonry-gallery">
        {
          product.gallery.map((image, index) => (
            <a
              href={fullImages[index].src}
              class="masonry-gallery__item wow fadeInUp"
              data-lightbox-trigger="product-lightbox"
              data-index={index}
              data-wow-delay={`${(index % 3) * 0.1}s`}
              aria-label={`View ${product.title} image ${index + 1}`}>
              <figure class="image-anime">
                <Image
                  src={image}
                  alt={`${product.title} image ${index + 1}`}
                  width={600}
                  loading="lazy"
                  format="webp"
                />
              </figure>
            </a>
          ))
        }
      </div>
    </div>
  </div>
  <!-- Page Product Gallery End -->

  <Lightbox images={lightboxImageUrls} id="product-lightbox" />
</Layout>

---
import Layout from "../../layouts/Layout.astro";
import PageHeader from "../../components/PageHeader.astro";
import { Image, getImage } from "astro:assets";
import { products } from "@/data/products";

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;

// Pre-generate full-size WebP versions for the lightbox
const fullImages = await Promise.all(
  product.gallery.map((img) => getImage({ src: img, format: "webp", width: 1600 })),
);
---

<Layout
  title={`${product.title} | BodyByAls`}
  description={product.description}>
  <PageHeader title={product.title} breadcrumb={product.title} parent={{ label: "Products", href: "/products" }} />

  <!-- Page Product Gallery Start -->
  <div class="page-team">
    <div class="container">
      <div class="masonry-gallery">
        {
          product.gallery.map((image, index) => (
            <a
              href={fullImages[index].src}
              class="masonry-gallery__item wow fadeInUp"
              data-lightbox-trigger
              data-index={index}
              data-wow-delay={`${(index % 3) * 0.1}s`}
              aria-label={`View ${product.title} image ${index + 1}`}>
              <figure class="image-anime">
                <Image
                  src={image}
                  alt={`${product.title} image ${index + 1}`}
                  width={600}
                  loading="lazy"
                  format="webp"
                />
              </figure>
            </a>
          ))
        }
      </div>
    </div>
  </div>
  <!-- Page Product Gallery End -->

  <!-- Lightbox -->
  <div class="lightbox" id="product-lightbox" hidden role="dialog" aria-modal="true" aria-label="Image viewer">
    <button class="lightbox__close" aria-label="Close" data-lightbox-close>&times;</button>
    <button class="lightbox__nav lightbox__prev" aria-label="Previous image" data-lightbox-prev>&#8249;</button>
    <button class="lightbox__nav lightbox__next" aria-label="Next image" data-lightbox-next>&#8250;</button>
    <img class="lightbox__image" alt="" />
    <div class="lightbox__counter"><span data-lightbox-current>1</span> of <span data-lightbox-total>{fullImages.length}</span></div>
  </div>

  <script define:vars={{ images: fullImages.map((i) => i.src) }} is:inline>
    (() => {
      const lightbox = document.getElementById("product-lightbox");
      if (!lightbox) return;
      const img = lightbox.querySelector(".lightbox__image");
      const currentEl = lightbox.querySelector("[data-lightbox-current]");
      const totalEl = lightbox.querySelector("[data-lightbox-total]");
      const triggers = document.querySelectorAll("[data-lightbox-trigger]");

      let currentIndex = 0;

      const show = (index) => {
        currentIndex = (index + images.length) % images.length;
        img.src = images[currentIndex];
        currentEl.textContent = currentIndex + 1;
        totalEl.textContent = images.length;
        lightbox.hidden = false;
        document.documentElement.classList.add("lightbox-open");
      };

      const hide = () => {
        lightbox.hidden = true;
        img.src = "";
        document.documentElement.classList.remove("lightbox-open");
      };

      triggers.forEach((trigger) => {
        trigger.addEventListener("click", (event) => {
          event.preventDefault();
          show(Number(trigger.dataset.index));
        });
      });

      lightbox.querySelector("[data-lightbox-close]").addEventListener("click", hide);
      lightbox.querySelector("[data-lightbox-prev]").addEventListener("click", () => show(currentIndex - 1));
      lightbox.querySelector("[data-lightbox-next]").addEventListener("click", () => show(currentIndex + 1));

      lightbox.addEventListener("click", (event) => {
        if (event.target === lightbox) hide();
      });

      document.addEventListener("keydown", (event) => {
        if (lightbox.hidden) return;
        if (event.key === "Escape") hide();
        else if (event.key === "ArrowLeft") show(currentIndex - 1);
        else if (event.key === "ArrowRight") show(currentIndex + 1);
      });
    })();
  </script>
</Layout>

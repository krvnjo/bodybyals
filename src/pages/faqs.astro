---
import Layout from "../layouts/Layout.astro";

const categories = [
  { id: "faq_1", title: "General Questions" },
  { id: "faq_2", title: "Program & Coaching" },
  { id: "faq_3", title: "Nutrition & Meal Plans" },
  { id: "faq_4", title: "Payment & Getting Started" },
  { id: "faq_5", title: "Results & Support" },
];

const faqSections = [
  {
    id: "faq_1",
    accordionId: "accordion",
    title: "General Questions",
    faqs: [
      {
        question: "Is BODYBYALS suitable for beginners?",
        answer:
          "<p>Yes. BODYBYALS is beginner-friendly. Our workouts are easy to follow, with proper form guidance and progressions based on your level, lifestyle, and goals.</p>",
      },
      {
        question: "Can I do BODYBYALS even if I'm busy or working full-time?",
        answer:
          "<p>Absolutely. Our program is designed for busy individuals. You can train at home or anywhere, at your own time and pace. We have clients all over the world including the Philippines, USA, Dubai, Singapore, Australia, and many more — so the program works across different schedules and time zones.</p>",
      },
      {
        question: "Is this program suitable for PCOS, insulin resistance, or postpartum clients?",
        answer:
          "<p>Yes. BODYBYALS focuses on controlling hormones and improving insulin sensitivity through proper training and nutrition.</p>",
      },
    ],
  },
  {
    id: "faq_2",
    accordionId: "accordion1",
    title: "Program & Coaching",
    faqs: [
      {
        question: "Do I need gym equipment?",
        answer:
          "<p>For beginners, we don't recommend lifting weights right away to prevent injuries. We start with bodyweight exercises to build proper form and foundation. For clients who already know how to work out, we can include weights based on your capacity and experience.</p>",
      },
      {
        question: "What's included in the BODYBYALS Online Coaching and Nutrition Guide?",
        answer: `<p>You'll get:</p>
          <ul>
            <li>A free consultation call before you join to answer all your questions</li>
            <li>Easy-to-follow workout programs tailored to your lifestyle</li>
            <li>Coach Anton's Nutrition Guide, discussed in a separate call</li>
            <li>Chat support where you can send meal photos and progress updates</li>
          </ul>`,
      },
      {
        question: "What makes BODYBYALS different from other programs?",
        answer: `<p>We focus on:</p>
          <ul>
            <li>Controlling hormones, not calorie counting</li>
            <li>A sustainable nutrition guide, not extreme dieting</li>
            <li>Real food and healthy carb alternatives</li>
            <li>Long-term results by building healthy habits</li>
          </ul>`,
      },
      {
        question: "Are BODYBYALS products required to join the program?",
        answer:
          "<p>No, they are optional. However, BODYBYALS Shirataki Rice and Keto Bread are great healthy carb alternatives to help you stay consistent while enjoying your meals.</p>",
      },
    ],
  },
  {
    id: "faq_3",
    accordionId: "accordion2",
    title: "Nutrition & Meal Plans",
    faqs: [
      {
        question: "What is the BODYBYALS Nutrition Guide? Is it keto?",
        answer: `<p>The BODYBYALS Nutrition Guide is an Insulin Sensitivity Reset Diet. We don't count calories. Instead, we focus on controlling hormones. This guide is suitable whether you have PCOS, want to lose weight, have hormonal imbalance, are trying to get pregnant, are postpartum, or simply want to be healthier overall.</p>
          <p>The guide teaches you what to eat, when to eat, what to avoid, and how to enjoy your favorite foods without guilt.</p>`,
      },
      {
        question: "What's included in the BODYBYALS Meal Plan?",
        answer:
          "<p>The meal plan is low-carb and high-protein, also called the Insulin Sensitivity Reset Diet. It's seed oil–free, chef-prepared and filling, and designed to support insulin sensitivity and hormone balance. Premium packages include USDA Prime Ribeye Steak and Salmon.</p>",
      },
      {
        question: "How many meals per day are included in the meal plan?",
        answer: `<p>We offer different options based on eating capacity:</p>
          <ul>
            <li><strong>Premium and Superior Packages:</strong> 2 meals per day, intentionally designed to support hormone balance and better insulin response. These are suitable for heavy eaters.</li>
            <li><strong>Lite Package:</strong> 2 bowls per day — 1 bowl for lunch and 1 bowl for dinner — suitable for light eaters.</li>
          </ul>`,
      },
      {
        question: "Can I customize my meal plan?",
        answer:
          "<p>Menu options vary by package. Our team will guide you in choosing the best option based on your goals and lifestyle.</p>",
      },
    ],
  },
  {
    id: "faq_4",
    accordionId: "accordion3",
    title: "Payment & Getting Started",
    faqs: [
      {
        question: "Is installment payment available?",
        answer: `<p><strong>For the BODYBYALS Meal Plan:</strong> Yes! Installment options are available and can be discussed during a call so we can explain the terms clearly and guide you properly.</p>
          <p><strong>For BODYBYALS Online Coaching & Nutrition Guide:</strong> Packages are paid in full. After proof of transaction, we will schedule another call to walk you through the Nutrition Guide.</p>`,
      },
      {
        question: "How do I start?",
        answer:
          "<p>You can book a free consultation call so we can explain the program and help you choose what's best for you.</p>",
      },
    ],
  },
  {
    id: "faq_5",
    accordionId: "accordion4",
    title: "Results & Support",
    faqs: [
      {
        question: "How does chat support work?",
        answer:
          "<p>Clients can send meal photos, questions, and progress updates through chat. Our team provides guidance and feedback to help you stay consistent and on track.</p>",
      },
      {
        question: "When will I start seeing results?",
        answer:
          "<p>Results depend on consistency. For BODYBYALS Online Coaching & Nutrition Guide, long-lasting results come from following the workouts and nutrition guide properly. The same applies to the Meal Plan — consistent adherence leads to better and sustainable results.</p>",
      },
    ],
  },
];

let globalIndex = 0;
---

<Layout
  title="FAQs | BodyByAls"
  description="Find answers to common questions about BodyByAls Online Coaching, nutrition guides, meal plans, and more. Learn how Coach Anton can help you transform your fitness journey.">
  <!-- Page Header Section Start -->
  <div class="page-header bg-section">
    <div class="container">
      <div class="row">
        <div class="col-lg-12">
          <!-- Page Header Box Start -->
          <div class="page-header-box">
            <h1 class="text-anime-style-3" data-cursor="-opaque">Frequently Asked Questions</h1>
            <nav class="wow fadeInUp">
              <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">home</a></li>
                <li class="breadcrumb-item active" aria-current="page">FAQs</li>
              </ol>
            </nav>
          </div>
          <!-- Page Header Box End -->
        </div>
      </div>
    </div>
  </div>
  <!-- Page Header Section End -->

  <!-- Page Faqs Start -->
  <div class="page-faqs">
    <div class="container">
      <div class="row">
        <div class="col-lg-4">
          <!-- Page Single Sidebar Start -->
          <div class="page-single-sidebar">
            <!-- Page Category List Start -->
            <div class="page-category-list wow fadeInUp">
              <ul>
                {
                  categories.map((category) => (
                    <li>
                      <a href={`#${category.id}`}>{category.title}</a>
                    </li>
                  ))
                }
              </ul>
            </div>
            <!-- Page Category List End -->
          </div>
          <!-- Page Single Sidebar End -->
        </div>

        <div class="col-lg-8">
          <!-- Page FAQs Category Start -->
          <div class="page-faqs-catagery">
            {
              faqSections.map((section) => (
                <div class="page-single-faqs" id={section.id}>
                  <div class="section-title">
                    <h2 class="text-anime-style-3" data-cursor="-opaque">
                      {section.title}
                    </h2>
                  </div>

                  <div class="faq-accordion our-faq-accordion" id={section.accordionId}>
                    {section.faqs.map((faq, faqIndex) => {
                      globalIndex++;
                      const isFirst = faqIndex === 0;
                      const delay = faqIndex > 0 ? `${faqIndex * 0.2}s` : null;

                      return (
                        <div class="accordion-item wow fadeInUp" data-wow-delay={delay}>
                          <h2 class="accordion-header" id={`heading${globalIndex}`}>
                            <button
                              class={`accordion-button ${!isFirst ? "collapsed" : ""}`}
                              type="button"
                              data-bs-toggle="collapse"
                              data-bs-target={`#collapse${globalIndex}`}
                              aria-expanded={isFirst ? "true" : "false"}
                              aria-controls={`collapse${globalIndex}`}>
                              Q{faqIndex + 1}. {faq.question}
                            </button>
                          </h2>
                          <div
                            id={`collapse${globalIndex}`}
                            class={`accordion-collapse collapse ${isFirst ? "show" : ""}`}
                            aria-labelledby={`heading${globalIndex}`}
                            data-bs-parent={`#${section.accordionId}`}>
                            <div class="accordion-body" set:html={faq.answer} />
                          </div>
                        </div>
                      );
                    })}
                  </div>
                </div>
              ))
            }
          </div>
          <!-- Page FAQs Category End -->
        </div>
      </div>
    </div>
  </div>
  <!-- Page Faqs End -->
</Layout>

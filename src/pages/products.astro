---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import { Image } from "astro:assets";
import { products } from "@/data/products";
---

<Layout
  title="Our Products | BodyByAls"
  description="Discover BodyByAls keto-friendly products. Dry Shirataki Rice, Keto Bread, and delicious Meal Plans designed to help you stay on track while enjoying your favorite foods.">
  <PageHeader title="Our Products" breadcrumb="Products" />

  <!-- Page Products Start -->
  {
    products.map((product, index) => (
      <div class="page-team-single py-3">
        <div class="container">
          <div class="row align-items-center">
            <div class="col-lg-12">
              <!-- Page Product Box Start -->
              <div class="page-team-single-box p-4">
                <!-- Product About Start -->
                <div class="team-member-about">
                  <!-- Product Image Start -->
                  <div class="team-single-image">
                    <figure class="image-anime">
                      <Image
                        src={product.image}
                        alt={product.title}
                        loading="lazy"
                        format="webp"
                      />
                    </figure>
                  </div>
                  <!-- Product Image End -->

                  <!-- Product Content Start -->
                  <div class="team-about-content">
                    <!-- Section Title Start -->
                    <div class="section-title">
                      <h2 class="text-anime-style-3">
                        <a href={`/products/${product.slug}`} class="product-title-link">{product.title}</a>
                      </h2>
                      <p class="wow fadeInUp">{product.description}</p>
                    </div>
                    <!-- Section Title End -->

                    <!-- Product Details List Start -->
                    <div class="team-contact-list wow fadeInUp" data-wow-delay="0.2s">
                      {product.details.map((detail) => (
                        <div class="team-contact-item">
                          <div class="icon-box">
                            <detail.icon color="#FFFFFF" size={24} stroke-width="1.5" />
                          </div>
                          <div class="team-contact-content">
                            <h3>{detail.label}</h3>
                            <p>{detail.value}</p>
                          </div>
                        </div>
                      ))}
                    </div>
                    <!-- Product Details List End -->

                    <!-- Shop Button Start -->
                    <div class="wow fadeInUp mt-4" data-wow-delay="0.4s">
                      <a href="https://bodybyals.passio.eco/" target="_blank" class="btn-default">
                        Shop Now
                      </a>
                    </div>
                    <!-- Shop Button End -->
                  </div>
                  <!-- Product Content End -->
                </div>
                <!-- Product About End -->
              </div>
              <!-- Page Product Box End -->
            </div>
          </div>
        </div>
      </div>
    ))
  }
  <!-- Page Products End -->
</Layout>
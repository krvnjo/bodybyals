---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="BodyByAls | Online Fitness Coaching & Sustainable Nutrition Guide"
  description="Transform your fitness journey with BodyByAls Online Coaching. Get easy-to-follow workouts, sustainable nutrition guidance, and hormone-based strategies from Coach Anton Soler. Train anywhere, eat smarter, and build lasting healthy habits.">
  <!-- Hero Section Start -->
  <section class="hero-royal bg-section dark-section">
    <div class="container">
      <div class="row">
        <div class="col-lg-12">
          <!-- Hero Content Start -->
          <div class="hero-content-royal">
            <!-- Section Title Start -->
            <div class="section-title">
              <h3 class="wow fadeInUp">Smart. Simple. Seamless.</h3>
              <h1 data-cursor="-opaque" class="text-anime-style-3">
                Thousands have TRANSFORMED<br />now it's your turn.
              </h1>
              <p data-wow-delay="0.2s" class="wow fadeInUp">
                Join the BodyByAls community and start your fitness journey today. Personalized coaching, nutrition
                guidance, and unwavering support.
              </p>
            </div>
            <!-- Section Title End -->

            <!-- Hero Image Box Start -->
            <div class="hero-image-box-royal">
              <!-- Hero Sales Box Start -->
              <div class="hero-sales-box-royal">
                <figure>
                  <img src="/images/hero-sales-img-royal.png" alt="" />
                </figure>
              </div>
              <!-- Hero Sales Box End -->

              <!-- Hero Image Start -->
              <div class="hero-image-royal">
                <figure>
                  <img src="/images/hero-image-royal.png" alt="" />
                </figure>
              </div>
              <!-- Hero Image End -->

              <!-- Hero Rating Box Start -->
              <div class="hero-rating-box-royal">
                <!-- Hero Rating Content Start -->
                <div class="hero-rating-content-royal">
                  <div class="hero-rating-header-royal">
                    <div class="icon-box">
                      <img src="/images/icon-hero-rating-header-royal.svg" alt="" />
                    </div>
                    <div class="hero-rating-header-content-royal">
                      <h3>Intuitive Design</h3>
                      <p>A clean, easy-to-use built for everyone.</p>
                    </div>
                  </div>
                  <div class="hero-rating-body-royal">
                    <div class="hero-rating-image-royal">
                      <img src="/images/icon-google-logo.svg" alt="" />
                    </div>
                    <div class="hero-rating-body-content-royal">
                      <p>
                        <i class="fa-solid fa-star"></i>
                        <i class="fa-solid fa-star"></i>
                        <i class="fa-solid fa-star"></i>
                        <i class="fa-solid fa-star"></i>
                        <i class="fa-solid fa-star"></i>
                      </p>
                      <h2><span class="counter">4.8</span></h2>
                    </div>
                  </div>
                </div>
                <!-- Hero Rating Content End -->

                <!-- Hero Rating Circle Start -->
                <div data-value="0.80" class="circle">
                  <div class="progress_value">
                    <span class="pro_data"></span><span>%</span><span class="circle-text">Task Completed</span>
                  </div>
                </div>
                <!-- Hero Rating Circle End -->
              </div>
              <!-- Hero Rating Box End -->
            </div>
            <!-- Hero Image Box End -->
          </div>
          <!-- Hero Content End -->
        </div>
      </div>
    </div>
  </section>
  <!-- Hero Section End -->

  <!-- About Section Start -->
  <section id="about" class="our-faqs">
    <div class="container">
      <div class="row">
        <div class="col-xl-5">
          <!-- Faq Image Box Start -->
          <div data-wow-delay="0.2s" class="faq-image-box-royal wow fadeInUp">
            <!-- Faq Image Start -->
            <div class="faq-image-royal">
              <figure class="image-anime">
                <img src="/images/faq-image-royal.jpg" alt="" />
              </figure>
            </div>
            <!-- Faq Image End -->

            <!-- Faq CTA Box Start -->
            <div class="faq-cta-box-royal">
              <!-- Satisfy Client Images Start -->
              <div class="satisfy-client-images">
                <div class="satisfy-client-image">
                  <figure class="image-anime">
                    <img src="/images/author-1.jpg" alt="" />
                  </figure>
                </div>
                <div class="satisfy-client-image">
                  <figure class="image-anime">
                    <img src="/images/author-2.jpg" alt="" />
                  </figure>
                </div>
                <div class="satisfy-client-image">
                  <figure class="image-anime">
                    <img src="/images/author-3.jpg" alt="" />
                  </figure>
                </div>
                <div class="satisfy-client-image">
                  <figure class="image-anime">
                    <img src="/images/author-4.jpg" alt="" />
                  </figure>
                </div>
              </div>
              <!-- Satisfy Client Images End -->

              <!-- Faq CTA Box Content Start -->
              <div class="faq-cta-box-content-royal">
                <h2><span class="counter">1000</span>+</h2>
                <p>Lives Transformed</p>
              </div>
              <!-- Faq CTA Box Content End -->
            </div>
            <!-- Faq CTA Box End -->
          </div>
          <!-- Faq Image Box End -->
        </div>

        <div class="col-xl-7">
          <!-- Faqs Content Start -->
          <div class="faqs-content-royal">
            <!-- Section Title Start -->
            <div class="section-title">
              <h3 class="wow fadeInUp">About Us</h3>
              <h2 data-cursor="-opaque" class="text-anime-style-3">Our Origin Story</h2>
              <p data-wow-delay="0.2s" class="wow fadeInUp">
                Coach Anton Soler founded BODYBYALS during the pandemic, but his journey started long before that.
                Growing up, he was a fat kid and struggled with weight, even though he was active in sports. He realized
                that being active alone wasn’t enough to get results, which sparked his interest in fitness and
                nutrition.<br /><br />
                Over the years, he tried different methods and learned from every experience. All of this taught him that
                lasting results come from controlling hormones and building sustainable habits, rather than just counting
                calories.<br /><br />
                Every day, his vision guides you through BODYBYALS Online Coaching with easy-to-follow workouts, a sustainable
                Nutrition Guide, and healthier carb alternatives like BODYBYALS Shirataki Rice and Keto Bread to support your
                fitness journey.<br /><br />
                Our approach is designed to be sustainable for every client, helping you stay on track while enjoying your
                favorite meals. No matter where you are in your day or your journey, your progress is our mission. Together,
                we’ll help you build healthier habits and turn your wellness goals into reality.
              </p>
            </div>
            <!-- Section Title End -->

            <!-- About Body Item List Start -->
            <div data-wow-delay="0.4s" class="about-us-body wow fadeInUp">
              <!-- About Body Item Start -->
              <div class="about-us-body-item">
                <div class="icon-box">
                  <img src="images/icon-about-body-item-1.svg" alt="" />
                </div>
                <div class="about-us-body-item-content">
                  <h3>Results That Last a Lifetime</h3>
                  <p>
                    We move beyond temporary fixes by prioritizing health and sustainable habits over restrictive
                    calorie counting.
                  </p>
                </div>
              </div>
              <!-- About Body Item End -->

              <!-- About Body Item Start -->
              <div class="about-us-body-item">
                <div class="icon-box">
                  <img src="images/icon-about-body-item-2.svg" alt="" />
                </div>
                <div class="about-us-body-item-content">
                  <h3>Your Progress, Our Mission</h3>
                  <p>
                    Achieve your wellness goals through a personalized approach that turns daily actions into a
                    sustainable reality.
                  </p>
                </div>
              </div>
              <!-- About Body Item End -->
            </div>
            <!-- About Body Item List End -->
          </div>
          <!-- Faqs Content End -->
        </div>
      </div>
    </div>
  </section>
  <!-- About Section End -->
</Layout>

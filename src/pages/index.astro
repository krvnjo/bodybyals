---
import Layout from "../layouts/Layout.astro";
import HeroSection from "../components/index/HeroSection.astro";
import AboutSection from "../components/index/AboutSection.astro";
import ServicesSection from "../components/index/ServicesSection.astro";

const testimonials = [
  {
    name: "Dianne Russell",
    job: "Freelancer",
    quote:
      "Our entire marketing team switched to this app for project tracking, and it's been a total game changer. The cross-platform sync is seamless, and collaboration has never been this smooth.",
  },
  {
    name: "Jane Cooper",
    job: "Marketing Manager",
    quote:
      "I've used so many productivity tools before, but none of them come close to this. The layout is clean, syncing is instant, and the features are so well thought out. It's truly made my days smoother.",
  },
  {
    name: "Maria Santos",
    job: "Working Mom",
    quote:
      "I never thought I could lose 15kg while juggling work and kids. Coach Als made the meal plans so easy to follow, and the workouts fit my busy schedule perfectly. Best decision I ever made.",
  },
  {
    name: "James Reyes",
    job: "Office Employee",
    quote:
      "From 95kg to 72kg in 6 months. The keto meal plan was a game changer, and Coach Als was there every step of the way. I finally feel confident in my own body.",
  },
];

const faqs = [
  {
    question: "Is BODYBYALS suitable for beginners?",
    answer:
      "Yes, BODYBYALS is beginner-friendly. Our workouts are easy to follow, with proper form guidance and progressions based on your level, lifestyle, and goals.",
  },
  {
    question: "Can I do BODYBYALS even if I’m busy or working full-time?",
    answer:
      "Absolutely. Our program is designed for busy individuals. You can train at home or anywhere, at your own time and pace. We have clients all over the world including the Philippines, USA, Dubai, Singapore, Australia, and many more so the program works across different schedules and time zones.",
  },
  {
    question: "Is this program suitable for PCOS, insulin resistance, or postpartum clients?",
    answer:
      "Yes, BODYBYALS focuses on controlling hormones and improving insulin sensitivity through proper training and nutrition.",
  },
  {
    question: "Do I need gym equipment?",
    answer:
      "For beginners, we don’t recommend lifting weights right away to prevent injuries. We start with bodyweight exercises to build proper form and foundation. For clients who already know how to work out, we can include weights based on your capacity and experience.",
  },
];
---

<Layout
  title="BodyByAls | Online Fitness Coaching & Sustainable Nutrition Guide"
  description="Transform your fitness journey with BodyByAls Online Coaching. Get easy-to-follow workouts, sustainable nutrition guidance, and hormone-based strategies from Coach Anton Soler. Train anywhere, eat smarter, and build lasting healthy habits.">
  <HeroSection />
  <AboutSection />
  <ServicesSection />

  <!-- Our Key Fact Section Start -->
  <section class="our-key-fact bg-section dark-section">
    <div class="container">
      <div class="row section-row">
        <div class="col-lg-12">
          <!-- Section Title Start -->
          <div class="section-title section-title-center">
            <h3 class="wow fadeInUp">Products</h3>
            <h2 data-cursor="-opaque" class="text-anime-style-3">Trusted by thousands powered by smart innovation</h2>
          </div>
          <!-- Section Title End -->
        </div>
      </div>

      <div class="row">
        <div class="col-xl-4 col-md-6">
          <!-- Key Fact Item Start -->
          <div class="key-fact-item wow fadeInUp">
            <!-- Key Fact Item Image Start -->
            <div class="key-fact-item-image">
              <figure>
                <img src="/images/key-fact-item-1.jpg" alt="" />
              </figure>
            </div>
            <!-- Key Fact Item Image End -->

            <!-- Key Fact Item Body Start -->
            <div class="key-fact-item-body">
              <!-- Key Fact Item Counter Start -->
              <div class="key-fact-item-counter">
                <h2><span class="counter">2500</span>+</h2>
              </div>
              <!-- Key Fact Item Counter End -->

              <!-- Key Fact Item Content Start -->
              <div class="key-fact-item-content">
                <h3>Tools & Platforms Integrated</h3>
                <p>We ensure your application runs smoothly with consistent uptime every month.</p>
              </div>
              <!-- Key Fact Item Content End -->
            </div>
            <!-- Key Fact Item Body End -->
          </div>
          <!-- Key Fact Item End -->
        </div>

        <div class="col-xl-4 col-md-6">
          <!-- Key Fact Item Start -->
          <div data-wow-delay="0.2s" class="key-fact-item wow fadeInUp">
            <!-- Key Fact Item Image Start -->
            <div class="key-fact-item-image">
              <figure>
                <img src="/images/key-fact-item-2.jpg" alt="" />
              </figure>
            </div>
            <!-- Key Fact Item Image End -->

            <!-- Key Fact Item Body Start -->
            <div class="key-fact-item-body">
              <!-- Key Fact Item Counter Start -->
              <div class="key-fact-item-counter">
                <h2><span class="counter">99.9</span>%</h2>
              </div>
              <!-- Key Fact Item Counter End -->

              <!-- Key Fact Item Content Start -->
              <div class="key-fact-item-content">
                <h3>Uptime Guaranteed Month</h3>
                <p>We ensure your application runs smoothly with consistent uptime every month.</p>
              </div>
              <!-- Key Fact Item Content End -->
            </div>
            <!-- Key Fact Item Body End -->
          </div>
          <!-- Key Fact Item End -->
        </div>

        <div class="col-xl-4 col-md-6">
          <!-- Key Fact Item Start -->
          <div data-wow-delay="0.4s" class="key-fact-item wow fadeInUp">
            <!-- Key Fact Item Image Start -->
            <div class="key-fact-item-image">
              <figure>
                <img src="/images/key-fact-item-3.jpg" alt="" />
              </figure>
            </div>
            <!-- Key Fact Item Image End -->

            <!-- Key Fact Item Body Start -->
            <div class="key-fact-item-body">
              <!-- Key Fact Item Counter Start -->
              <div class="key-fact-item-counter">
                <h2><span class="counter">24</span>/7</h2>
              </div>
              <!-- Key Fact Item Counter End -->

              <!-- Key Fact Item Content Start -->
              <div class="key-fact-item-content">
                <h3>Customer Support Availability</h3>
                <p>We ensure your application runs smoothly with consistent uptime every month.</p>
              </div>
              <!-- Key Fact Item Content End -->
            </div>
            <!-- Key Fact Item Body End -->
          </div>
          <!-- Key Fact Item End -->
        </div>
      </div>

      <div class="col-lg-12">
        <!-- Section Footer Text Start -->
        <div data-wow-delay="0.4s" class="section-footer-text wow fadeInUp">
          <p><span>Free</span>Let's make something great work together.<a href="#"> Get Free Quote</a></p>
        </div>
        <!-- Section Footer Text End -->
      </div>
    </div>
  </section>
  <!-- Our Key Fact Section End -->

  <!-- Our Interface Section Start -->
  <section class="our-interface">
    <div class="container">
      <div class="row section-row">
        <div class="col-lg-12">
          <!-- Section Title Start -->
          <div class="section-title section-title-center">
            <h3 class="wow fadeInUp">Transformations</h3>
            <h2 data-cursor="-opaque" class="text-anime-style-3">Preview the app through detailed screen displays</h2>
          </div>
          <!-- Section Title End -->
        </div>
      </div>

      <div class="row">
        <!-- Our Interface Slider Start -->
        <div class="our-interface-slider">
          <div class="swiper">
            <div data-cursor-text="Drag" class="swiper-wrapper">
              <!-- Company Support Logo Start -->
              <div class="swiper-slide">
                <div class="interface-slider-image">
                  <img src="/images/interface-slider-image-1.jpg" alt="" />
                </div>
              </div>
              <!-- Company Support Logo End -->

              <!-- Company Support Logo Start -->
              <div class="swiper-slide">
                <div class="interface-slider-image">
                  <img src="/images/interface-slider-image-2.jpg" alt="" />
                </div>
              </div>
              <!-- Company Support Logo End -->

              <!-- Company Support Logo Start -->
              <div class="swiper-slide">
                <div class="interface-slider-image">
                  <img src="/images/interface-slider-image-3.jpg" alt="" />
                </div>
              </div>
              <!-- Company Support Logo End -->

              <!-- Company Support Logo Start -->
              <div class="swiper-slide">
                <div class="interface-slider-image">
                  <img src="/images/interface-slider-image-4.jpg" alt="" />
                </div>
              </div>
              <!-- Company Support Logo End -->

              <!-- Company Support Logo Start -->
              <div class="swiper-slide">
                <div class="interface-slider-image">
                  <img src="/images/interface-slider-image-5.jpg" alt="" />
                </div>
              </div>
              <!-- Company Support Logo End -->

              <!-- Company Support Logo Start -->
              <div class="swiper-slide">
                <div class="interface-slider-image">
                  <img src="/images/interface-slider-image-3.jpg" alt="" />
                </div>
              </div>
              <!-- Company Support Logo End -->
            </div>
            <div class="interface-pagination"></div>
          </div>
        </div>
        <!-- Our Interface Slider End -->
      </div>
    </div>
  </section>
  <!-- Our Interface Section End -->

  <!-- Our Testimonial Section Start -->
  <section class="our-testimonial-elite bg-section dark-section">
    <div class="container">
      <div class="row section-row">
        <div class="col-lg-12">
          <!-- Section Title Start -->
          <div class="section-title section-title-center">
            <h3 class="wow fadeInUp">Our Testimonials</h3>
            <h2 data-cursor="-opaque" class="text-anime-style-3">
              From all over the world, real people achieving real results with us
            </h2>
          </div>
          <!-- Section Title End -->
        </div>
      </div>

      <div class="row">
        <div class="col-xl-12">
          <!-- Testimonial Slider Start -->
          <div class="testimonial-slider-elite">
            <div class="swiper">
              <div data-cursor-text="Drag" class="swiper-wrapper">
                {
                  testimonials.map((testimonial) => (
                    <div class="swiper-slide">
                      <div class="testimonial-item-elite">
                        <div class="testimonial-company-logo-elite">
                          <img src="/images/company-logo-1-elite.svg" alt="" />
                        </div>
                        <div class="testimonial-item-body-elite">
                          <div class="testimonial-item-content-elite">
                            <h3>" {testimonial.quote} "</h3>
                          </div>
                          <div class="testimonial-item-footer-elite">
                            <div class="testimonial-author-content-elite">
                              <h3>{testimonial.name}</h3>
                              <p>{testimonial.job}</p>
                            </div>
                            <div class="testimonial-quote-elite">
                              <img src="/images/testimonial-quote-elite.svg" alt="" />
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                  ))
                }
              </div>
            </div>
          </div>
          <!-- Testimonial Slider End -->
        </div>

        <div class="col-lg-12">
          <!-- Section Footer Text Start -->
          <div data-wow-delay="0.4s" class="section-footer-text section-satisfy-img wow fadeInUp">
            <!-- Satisfy Client Images Start -->
            <div class="satisfy-client-images">
              <div class="satisfy-client-image">
                <figure class="image-anime">
                  <img src="/images/author-4.jpg" alt="" />
                </figure>
              </div>
              <div class="satisfy-client-image add-more">
                <img src="/images/icon-phone-primary.svg" alt="" />
              </div>
            </div>
            <!-- Satisfy Client Images End -->
            <p>Join our team and help weave innovation, quality, and success together worldwide.</p>
            <ul>
              <li><span class="counter">4.9</span>/5</li>
              <li>
                <i class="fa-solid fa-star"></i>
                <i class="fa-solid fa-star"></i>
                <i class="fa-solid fa-star"></i>
                <i class="fa-solid fa-star"></i>
                <i class="fa-solid fa-star"></i>
              </li>
              <li>Over 4200 Reviews</li>
            </ul>
          </div>
          <!-- Section Footer Text End -->
        </div>
      </div>
    </div>
  </section>
  <!-- Our Testimonial Section End -->

  <!-- Our Faqs Section Start -->
  <section id="faqs" class="our-faqs">
    <div class="container">
      <div class="row">
        <div class="col-xl-5">
          <!-- Faqs Content Box Start -->
          <div class="faqs-content-box">
            <!-- Faqs Content Start -->
            <div class="faqs-content">
              <!-- Section Title Start -->
              <div class="section-title">
                <h3 class="wow fadeInUp">Frequently Asked Questions</h3>
                <h2 data-cursor="-opaque" class="text-anime-style-3">All the answers you need to get started</h2>
                <p data-wow-delay="0.2s" class="wow fadeInUp">
                  Whether you're curious about setup, features, or troubleshooting, our FAQ section covers everything
                  you need for a smooth and seamless experience.
                </p>
              </div>
              <!-- Section Title End -->

              <!-- Faqs Button Start -->
              <div data-wow-delay="0.4s" class="faq-btn wow fadeInUp">
                <a href="#" class="btn-default">View all FAQ's</a>
              </div>
              <!-- Faqs Button End -->
            </div>
            <!-- Faqs Content End -->

            <!-- Faqs CTA Box Start -->
            <div data-wow-delay="0.6s" class="faqs-cta-box wow fadeInUp">
              <!-- Faqs CTA Box Header Start -->
              <div class="faqs-cta-box-header">
                <div class="faqs-cta-box-counter">
                  <h2><span class="counter">4.9</span>/5.0</h2>
                </div>
                <div class="faqs-cta-box-counter-content">
                  <p>Loved by users world-wide for design</p>
                </div>
              </div>
              <!-- Faqs CTA Box Header End -->

              <!-- Faqs CTA Box Body Start -->
              <div class="faqs-cta-body">
                <div class="faqs-cta-body-content">
                  <p>User Satisfaction Rating</p>
                </div>
                <!-- Satisfy Client Images Start -->
                <div class="satisfy-client-images">
                  <div class="satisfy-client-image">
                    <figure class="image-anime">
                      <img src="/images/author-1.jpg" alt="" />
                    </figure>
                  </div>
                  <div class="satisfy-client-image">
                    <figure class="image-anime">
                      <img src="/images/author-2.jpg" alt="" />
                    </figure>
                  </div>
                  <div class="satisfy-client-image">
                    <figure class="image-anime">
                      <img src="/images/author-3.jpg" alt="" />
                    </figure>
                  </div>
                  <div class="satisfy-client-image">
                    <figure class="image-anime">
                      <img src="/images/author-4.jpg" alt="" />
                    </figure>
                  </div>
                </div>
                <!-- Satisfy Client Images End -->
              </div>
              <!-- Faqs CTA Box Body End -->
            </div>
            <!-- Faqs CTA Box End -->
          </div>
          <!-- Faqs Content Box End -->
        </div>

        <div class="col-xl-7">
          <!-- FAQ Accordion Start -->
          <div id="accordion" class="faq-accordion">
            <!-- FAQ Item Start -->
            {
              faqs.map((faq, index) => (
                <div data-wow-delay={index !== 0 ? `${index * 0.2}s` : undefined} class="accordion-item wow fadeInUp">
                  <h2 id={`heading${index + 1}`} class="accordion-header">
                    <button
                      type="button"
                      data-bs-toggle="collapse"
                      data-bs-target={`#collapse${index + 1}`}
                      aria-expanded={index === 0 ? "true" : "false"}
                      aria-controls={`collapse${index + 1}`}
                      class={`accordion-button ${index !== 0 ? "collapsed" : ""}`}>
                      Q{index + 1}. {faq.question}
                    </button>
                  </h2>
                  <div
                    id={`collapse${index + 1}`}
                    data-bs-parent="#accordion"
                    aria-labelledby={`heading${index + 1}`}
                    class={`accordion-collapse collapse ${index === 0 ? "show" : ""}`}>
                    <div class="accordion-body">
                      <p>{faq.answer}</p>
                    </div>
                  </div>
                </div>
              ))
            }
            <!-- FAQ Item End -->
          </div>
          <!-- FAQ Accordion End -->
        </div>
      </div>
    </div>
  </section>
  <!-- Our Faqs Section End -->
</Layout>

---

<Layout
  title="Client Testimonials | BodyByAls"
  description="Read real success stories from BodyByAls clients worldwide. Discover how Coach Anton's fitness coaching and nutrition guidance has transformed lives.">
  <!-- Page Header Section Start -->
  <div class="page-header bg-section">
    <div class="container">
      <div class="row">
        <div class="col-lg-12">
          <!-- Page Header Box Start -->
          <div class="page-header-box">
            <h1 class="text-anime-style-3" data-cursor="-opaque">Client Transformations</h1>
            <nav class="wow fadeInUp">
              <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Home</a></li>
                <li class="breadcrumb-item active" aria-current="page">Transformations</li>
              </ol>
            </nav>
          </div>
          <!-- Page Header Box End -->
        </div>
      </div>
    </div>
  </div>
  <!-- Page Header Section End -->

  <!-- Transformations Section Start -->
  <section id="transformations" class="our-interface">
    <div class="container">
      <div class="row section-row">
        <div class="col-lg-12">
          <!-- Section Title Start -->
          <div class="section-title section-title-center">
            <h3 class="wow fadeInUp">Transformations</h3>
            <h2 data-cursor="-opaque" class="text-anime-style-3">
              Real results from real clients who trusted the process
            </h2>
          </div>
          <!-- Section Title End -->
        </div>
      </div>

      <div class="row">
        <!-- Transformations Slider Start -->
        <div class="our-interface-slider">
          <div class="swiper">
            <div data-cursor-text="Drag" class="swiper-wrapper">
              {
                transformations.map((image, index) => (
                  <div class="swiper-slide">
                    <div class="interface-slider-image">
                      <Image
                        src={image}
                        alt={`Client transformation ${index + 1}`}
                        width={500}
                        height={850}
                        loading="lazy"
                        format="webp"
                      />
                    </div>
                  </div>
                ))
              }
            </div>
            <div class="interface-pagination"></div>
          </div>
        </div>
        <!-- Transformations Slider End -->
      </div>
    </div>
  </section>
  <!-- Transformations Section End -->

  <!-- Page Testimonials Start -->
  <div class="page-testimonials">
    <div class="container">
      <div class="row" id="testimonials-grid">
        {
          testimonials.map((testimonial, index) => (
            <div class:list={["col-md-6", "testimonial-col", { hidden: index >= INITIAL_COUNT }]}>
              <div class="testimonial-item wow fadeInUp" data-wow-delay={`${(index % 2) * 0.2}s`}>
                <div class="testimonial-item-header">
                  <div class="testimonial-item-rating">
                    <i class="fa fa-solid fa-star" />
                    <i class="fa fa-solid fa-star" />
                    <i class="fa fa-solid fa-star" />
                    <i class="fa fa-solid fa-star" />
                    <i class="fa fa-solid fa-star" />
                  </div>
                  <div class="testimonial-item-content">
                    <h3>"{testimonial.title}"</h3>
                    <p>"{testimonial.quote}"</p>
                  </div>
                </div>

                <div class="testimonial-item-body">
                  <div class="testimonial-item-author">
                    <div class="testimonial-author-content">
                      <h3>{testimonial.name}</h3>
                      <p>{testimonial.job}</p>
                    </div>
                  </div>

                  <div class="testimonials-item-quotes">
                    <figure>
                      <img src="/images/testimonial-quote-emerald.svg" alt="" />
                    </figure>
                  </div>
                </div>
              </div>
            </div>
          ))
        }
      </div>

      <!-- Show More Button Start -->
      <div class="row">
        <div class="col-lg-12 text-center mt-4">
          <button id="show-more-btn" class="btn-default" type="button">Show More</button>
        </div>
      </div>
      <!-- Show More Button End -->
    </div>
  </div>
  <!-- Page Testimonials End -->
</Layout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const btn = document.getElementById("show-more-btn");
    const hiddenItems = document.querySelectorAll(".testimonial-col.hidden");

    if (!btn) return;

    if (hiddenItems.length === 0) {
      btn.style.display = "none";
      return;
    }

    let expanded = false;

    btn.addEventListener("click", () => {
      expanded = !expanded;

      hiddenItems.forEach((item) => {
        item.classList.toggle("hidden", !expanded);
      });

      btn.textContent = expanded ? "Show Less" : "Show More";
    });
  });
</script>

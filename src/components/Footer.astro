---
import { Image } from "astro:assets";
import footerLogo from "@/assets/images/logos/logo.svg";
import locationIcon from "@/assets/images/icons/icon-location-light.svg";
import mailIcon from "@/assets/images/icons/icon-mail-light.svg";

const year = new Date().getFullYear();
const { currentPath } = Astro.props;
const isHomePage = currentPath === "/";
---

<!-- Footer Start -->
<footer id="footer" class="main-footer-royal bg-section dark-section">
  <div class="container">
    <div class="row">
      <div class="col-lg-4">
        <!-- About Footer Start -->
        <div class="about-footer-royal">
          <!-- Footer Logo Start -->
          <div class="footer-logo-royal">
            <Image src={footerLogo} alt="BodyByAls Logo" style="width: 165px; height: 50px;" />
          </div>
          <!-- Footer Logo End -->

          <!-- About Footer Content Start -->
          <div class="about-footer-content-royal">
            <p>
              Transforming lives through sustainable fitness and nutrition with balance and consistency, empowering you
              to maintain healthy habits for life.
            </p>
          </div>
          <!-- About Footer Content End -->
        </div>
        <!-- About Footer End -->
      </div>

      <div class="col-lg-8">
        <!-- Footer Links Box Start -->
        <div class="footer-links-box-royal">
          <!-- Footer Links Start -->
          <div class="footer-links-royal">
            <h3>Quick Links</h3>
            <ul>
              <li><a href={isHomePage ? "#about" : "/#about"}>About</a></li>
              <li><a href="/services">Services</a></li>
              <li><a href="/products">Products</a></li>
              <li><a href="/transformations">Transformations</a></li>
            </ul>
          </div>
          <!-- Footer Links End -->

          <!-- Footer Links Start -->
          <div class="footer-links-royal">
            <h3>Support</h3>
            <ul>
              <li><a href={isHomePage ? "#get-started" : "/#get-started"}>Get Started</a></li>
              <li><a href="/faqs">FAQs</a></li>
            </ul>
          </div>
          <!-- Footer Links End -->

          <!-- Footer Links Start -->
          <div class="footer-links-royal footer-contact-links-royal">
            <h3>Get In touch</h3>
            <ul>
              <li>
                <Image src={locationIcon} alt="" />
                Quezon City, Philippines
              </li>
              <li>
                <Image src={mailIcon} alt="" />
                <a class="text-lowercase" href="mailto:bodybyals.business@gmail.com">bodybyals.business@gmail.com</a>
              </li>
            </ul>
          </div>
          <!-- Footer Links End -->
        </div>
        <!-- Footer Links Box End -->
      </div>

      <div class="col-lg-12">
        <!-- Footer Copyright Start -->
        <div class="footer-copyright-elite">
          <!-- Footer Copyright Text Start -->
          <div class="footer-copyright-text-elite">
            <p>© {year} BodyByAls. All Rights Reserved.</p>
          </div>
          <!-- Footer Copyright Text End -->

          <!-- Footer Social Link Start -->
          <div class="footer-social-links-elite">
            <h3>Follow Us On Socials:</h3>
            <ul>
              <li>
                <a href="https://www.facebook.com/BODYBYALS" target="_blank" aria-label="Facebook">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path
                      d="M9.101 23.691v-7.98H6.627v-3.667h2.474v-1.58c0-4.085 1.848-5.978 5.858-5.978.401 0 .955.042 1.468.103a8.68 8.68 0 0 1 1.141.195v3.325a8.623 8.623 0 0 0-.653-.036 26.805 26.805 0 0 0-.733-.009c-.707 0-1.259.096-1.675.309a1.686 1.686 0 0 0-.679.622c-.258.42-.374.995-.374 1.752v1.297h3.919l-.386 2.103-.287 1.564h-3.246v8.245C19.396 23.238 24 18.179 24 12.044c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.628 3.874 10.35 9.101 11.647Z"
                    />
                  </svg>
                </a>
              </li>
              <li>
                <a href="https://www.instagram.com/bodybyals/" target="_blank" aria-label="Instagram">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path
                      d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"
                    />
                  </svg>
                </a>
              </li>
              <li>
                <a href="https://www.tiktok.com/@bodybyals" target="_blank" aria-label="TikTok">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path
                      d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1.84-.1z"
                    />
                  </svg>
                </a>
              </li>
              <li>
                <a
                  href="https://www.threads.com/@bodybyals?xmt=AQF0-Wsfdj1zmUVDy4x-itGYnUPm8_hXjDRUmA05tXUSEG4"
                  target="_blank"
                  aria-label="Threads">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path
                      d="M12.186 24h-.007c-3.581-.024-6.334-1.205-8.184-3.509C2.35 18.44 1.5 15.586 1.472 12.01v-.017c.03-3.579.879-6.43 2.525-8.482C5.845 1.205 8.6.024 12.18 0h.014c2.746.02 5.043.725 6.826 2.098 1.677 1.29 2.858 3.13 3.509 5.467l-2.04.569c-1.104-3.96-3.898-5.984-8.304-6.015-2.91.022-5.11.936-6.54 2.717C4.307 6.504 3.616 8.914 3.589 12c.027 3.086.718 5.496 2.057 7.164 1.43 1.781 3.631 2.695 6.54 2.717 2.623-.02 4.358-.631 5.8-2.045 1.647-1.613 1.618-3.593 1.09-4.798-.31-.71-.873-1.3-1.634-1.75-.192 1.352-.622 2.446-1.284 3.272-.886 1.102-2.14 1.704-3.73 1.79-1.202.065-2.361-.218-3.259-.801-1.063-.689-1.685-1.74-1.752-2.964-.065-1.19.408-2.285 1.33-3.082.88-.76 2.119-1.207 3.583-1.291a13.853 13.853 0 0 1 3.02.142c-.126-.742-.375-1.332-.75-1.757-.513-.586-1.308-.883-2.359-.89h-.029c-.844 0-1.992.232-2.721 1.32L7.8 8.366c.98-1.454 2.568-2.256 4.471-2.256h.044c3.187.02 5.087 1.969 5.275 5.366q.16.066.314.139c1.474.692 2.554 1.74 3.124 3.03.795 1.798.866 4.732-1.524 7.071-1.83 1.792-4.05 2.605-7.298 2.628Zm1.043-11.0388c-.323 0-.652.01-.987.027-1.84.103-2.987.948-2.91 2.32.082 1.435 1.66 2.103 3.18 2.02 1.397-.073 3.221-.62 3.532-4.116a12.835 12.835 0 0 0-2.815-.251Z"
                    />
                  </svg>
                </a>
              </li>
            </ul>
          </div>
          <!-- Footer Social Link End -->
        </div>
        <!-- Footer Copyright End -->
      </div>
    </div>
  </div>
</footer>
<!-- Footer End -->

<script>
  document.querySelectorAll(".footer-links-royal h3").forEach((header) => {
    header.addEventListener("click", () => {
      const parent = header.parentElement;
      if (!parent) return;

      // Close others
      document.querySelectorAll(".footer-links-royal").forEach((item) => {
        if (item !== parent) {
          item.classList.remove("active");
        }
      });

      // Toggle current
      parent.classList.toggle("active");
    });
  });
</script>

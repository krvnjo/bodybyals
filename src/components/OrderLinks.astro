---
import { Image } from "astro:assets";
import { orderLinks } from "@/data/products";
import lazadaLogo from "@/assets/images/icons/lazada.png";

interface Props {
  note?: string;
  getStartedForm?: string;
}

const { note, getStartedForm } = Astro.props;
---

<div class="order-links">
  <div class="section-title section-title-center">
    <h3 class="wow fadeInUp">Where to Order</h3>
    <h2 class="text-anime-style-3">Take the first step toward your goals —<br />order on your favorite platform</h2>
  </div>

  {
    note && (
      <div class="order-links__note">
        <p class="order-links__desc">{note}</p>
      </div>
    )
  }
  <div class="order-links__list">
    {
      getStartedForm && (
        <a
          href={getStartedForm}
          target="_blank"
          rel="noopener noreferrer"
          class="order-link order-link--form"
          aria-label="Meal Plan Packages">
          <span class="order-link__icon">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true">
              <path d="M9 2h6a1 1 0 0 1 1 1v1h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2V3a1 1 0 0 1 1-1z" />
              <path d="M9 4h6" />
              <path d="M8 11h8M8 15h5" />
            </svg>
          </span>
          <span class="order-link__label">Meal Plan Packages</span>
        </a>
      )
    }
    {
      orderLinks.map((link) => (
        <a
          href={link.url || undefined}
          target={link.url ? "_blank" : undefined}
          rel={link.url ? "noopener noreferrer" : undefined}
          class={`order-link order-link--${link.platform}${link.url ? "" : " order-link--disabled"}`}
          aria-label={link.url ? `Order on ${link.label}` : `${link.label} — coming soon`}>
          <span class="order-link__icon">
            {link.platform === "shopee" && (
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 1.5a3.94 3.94 0 0 0-3.94 3.94V6H4.2a.75.75 0 0 0-.75.79l.78 14.06A1.5 1.5 0 0 0 5.73 22.3h12.54a1.5 1.5 0 0 0 1.5-1.42l.78-14.06A.75.75 0 0 0 19.8 6h-3.86v-.56A3.94 3.94 0 0 0 12 1.5zm0 1.5a2.44 2.44 0 0 1 2.44 2.44V6H9.56v-.56A2.44 2.44 0 0 1 12 3zm-3.4 8.1c0-1.3 1.1-2.16 2.74-2.16 1 0 1.86.27 2.5.66l-.6 1.2a3.4 3.4 0 0 0-1.9-.55c-.7 0-1.16.28-1.16.7 0 .46.5.63 1.46.94 1.3.42 2.2.93 2.2 2.16 0 1.4-1.13 2.2-2.86 2.2-1.06 0-2.04-.32-2.7-.82l.64-1.16c.56.42 1.32.66 2.06.66.78 0 1.27-.3 1.27-.76 0-.5-.55-.68-1.5-1-1.27-.42-2.1-.92-2.1-2.07z" />
              </svg>
            )}
            {link.platform === "tiktok" && (
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1.84-.1z" />
              </svg>
            )}
            {link.platform === "lazada" && <Image src={lazadaLogo} alt="" width={64} height={64} format="webp" />}
            {link.platform === "instagram" && (
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2.16c3.2 0 3.58.01 4.85.07 3.25.15 4.77 1.69 4.92 4.92.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.15 3.23-1.66 4.77-4.92 4.92-1.27.06-1.64.07-4.85.07s-3.58-.01-4.85-.07c-3.26-.15-4.77-1.7-4.92-4.92-.06-1.27-.07-1.64-.07-4.85s.01-3.58.07-4.85C2.38 3.92 3.9 2.38 7.15 2.23 8.42 2.17 8.8 2.16 12 2.16zM12 0C8.74 0 8.33.01 7.05.07 2.7.27.28 2.69.08 7.05.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.2 4.36 2.62 6.78 6.98 6.98C8.33 23.99 8.74 24 12 24s3.67-.01 4.95-.07c4.35-.2 6.78-2.62 6.98-6.98.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.2-4.35-2.62-6.78-6.98-6.98C15.67.01 15.26 0 12 0zm0 5.84a6.16 6.16 0 1 0 0 12.32 6.16 6.16 0 0 0 0-12.32zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.41-11.85a1.44 1.44 0 1 0 0 2.88 1.44 1.44 0 0 0 0-2.88z" />
              </svg>
            )}
          </span>
          <span class="order-link__label">{link.label}</span>
        </a>
      ))
    }
  </div>

  <div class="section-footer-text order-links__contact">
    {
      getStartedForm ? (
        <p>
          📝 To order, fill out our Google Form to view available plans. For inquiries, message us directly on Facebook
          or Instagram.
        </p>
      ) : (
        <p>📍 Available for pick-up in Quezon City. Just message us directly on Facebook or Instagram.</p>
      )
    }
  </div>
</div>

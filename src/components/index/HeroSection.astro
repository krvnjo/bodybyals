---
import avatar1 from "@/assets/images/avatars/avatar-1.png";
import avatar2 from "@/assets/images/avatars/avatar-2.png";
import avatar3 from "@/assets/images/avatars/avatar-3.png";
import avatar4 from "@/assets/images/avatars/avatar-4.png";
import avatar5 from "@/assets/images/avatars/avatar-5.png";
---

<!-- Hero Section Start -->
<section class="hero-elite bg-section hero-bg">
  <div class="container">
    <div class="row">
      <div class="col-lg-12">
        <!-- Hero Content Start -->
        <div class="hero-content-royal">
          <!-- Section Title Start -->
          <div class="section-title">
            <h3 class="wow fadeInUp text-light">Train. Transform. Thrive.</h3>
            <h1 data-cursor="-opaque" class="text-anime-style-3">
              <span class="text-line text-light">Thousands have TRANSFORMED</span>
              <span class="text-line text-light">now it's your turn.</span>
            </h1>
            <p data-wow-delay="0.2s" class="text-light wow fadeInUp">
              Join the BodyByAls community and start your fitness journey today. Personalized coaching, nutrition
              guidance, and unwavering support.
            </p>
          </div>
          <!-- Section Title End -->

          <!-- Hero Content Body Start -->
          <div data-wow-delay="0.4s" class="hero-content-body-elite wow fadeInUp">
            <!-- Hero Button Start -->
            <div class="hero-btn-elite">
              <a href="#" class="btn-default btn-highlighted">Start Your Transformation</a>
            </div>
            <!-- Hero Button End -->
          </div>
          <!-- Hero Content Body End -->
        </div>
        <!-- Hero Content End -->

        <!-- Hero Image Box Start -->
        <div class="hero-image-box-elite">
          <!-- Hero Circle Progress Box Start -->
          <div class="hero-circle-progress-box-elite">
            <div class="hero-circle-progress-header-elite">
              <h3>Weekly Task</h3>
              <p>Plan and manage your week easily</p>
            </div>
            <div data-value="0.80" class="circle">
              <div class="progress_value">
                <span class="pro_data"></span><span>%</span><span class="circle-text">Task Completed</span>
              </div>
            </div>
          </div>
          <!-- Hero Circle Progress Box End -->

          <!-- Hero Client Box Start -->
          <div class="hero-client-box-elite">
            <!-- Hero Client header Start -->
            <div class="hero-client-header-elite">
              <p class="text-light">Engaged Daily Users</p>
              <h2 class="text-light"><span class="counter">500</span>K+</h2>
            </div>
            <!-- Hero Client header End -->

            <!-- Hero Client Body Start -->
            <div class="hero-client-body-elite">
              <!-- Satisfy Client Images Start -->
              <div class="satisfy-client-images">
                <div class="satisfy-client-image">
                  <figure class="image-anime">
                    <img src={avatar1.src} alt="" />
                  </figure>
                </div>
                <div class="satisfy-client-image">
                  <figure class="image-anime">
                    <img src={avatar2.src} alt="" />
                  </figure>
                </div>
                <div class="satisfy-client-image">
                  <figure class="image-anime">
                    <img src={avatar3.src} alt="" />
                  </figure>
                </div>
                <div class="satisfy-client-image">
                  <figure class="image-anime">
                    <img src={avatar4.src} alt="" />
                  </figure>
                </div>
                <div class="satisfy-client-image">
                  <figure class="image-anime">
                    <img src={avatar5.src} alt="" />
                  </figure>
                </div>
              </div>
              <!-- Satisfy Client Images End -->
            </div>
            <!-- Hero Client Body End -->
          </div>
          <!-- Hero Client Box End -->

          <!-- Hero Image Start -->
          <div class="hero-image-elite">
            <figure>
              <img src="/images/hero-image-elite.png" alt="" />
            </figure>
          </div>
          <!-- Hero Image End -->
        </div>
        <!-- Hero Image Box End -->
      </div>
    </div>
  </div>
</section>
<!-- Hero Section End -->

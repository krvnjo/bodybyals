---
import { Image } from "astro:assets";
import transformation1 from "@/assets/images/transformations/transformation-1.png";
import transformation2 from "@/assets/images/transformations/transformation-2.png";
import transformation3 from "@/assets/images/transformations/transformation-3.png";
import transformation4 from "@/assets/images/transformations/transformation-4.png";
import transformation5 from "@/assets/images/transformations/transformation-5.png";
import transformation6 from "@/assets/images/transformations/transformation-6.png";
import transformation7 from "@/assets/images/transformations/transformation-7.png";
import transformation8 from "@/assets/images/transformations/transformation-8.png";

const transformations = [
  transformation1,
  transformation2,
  transformation3,
  transformation4,
  transformation5,
  transformation6,
  transformation7,
  transformation8,
];
---

<!-- Transformations Section Start -->
<section id="transformations" class="our-interface">
  <div class="container">
    <div class="row section-row">
      <div class="col-lg-12">
        <!-- Section Title Start -->
        <div class="section-title section-title-center">
          <h3 class="wow fadeInUp">Transformations</h3>
          <h2 data-cursor="-opaque" class="text-anime-style-3">
            Real results from real clients who trusted the process
          </h2>
        </div>
        <!-- Section Title End -->
      </div>
    </div>

    <div class="row">
      <!-- Transformations Slider Start -->
      <div class="our-interface-slider">
        <div class="swiper">
          <div class="swiper-wrapper">
            {
              transformations.map((image, index) => (
                <div class="swiper-slide">
                  <div class="interface-slider-image">
                    <Image
                      src={image}
                      alt={`Client transformation ${index + 1}`}
                      width={500}
                      height={850}
                      loading="lazy"
                      format="webp"
                    />
                  </div>
                </div>
              ))
            }
          </div>
          <div class="interface-pagination"></div>
        </div>
      </div>
      <!-- Transformations Slider End -->
    </div>
  </div>
</section>
<!-- Transformations Section End -->

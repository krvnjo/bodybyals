---
const testimonials = [
  {
    name: "Dianne Russell",
    job: "Freelancer",
    quote:
      "Our entire marketing team switched to this app for project tracking, and it's been a total game changer. The cross-platform sync is seamless, and collaboration has never been this smooth.",
  },
  {
    name: "Jane Cooper",
    job: "Marketing Manager",
    quote:
      "I've used so many productivity tools before, but none of them come close to this. The layout is clean, syncing is instant, and the features are so well thought out. It's truly made my days smoother.",
  },
  {
    name: "Maria Santos",
    job: "Working Mom",
    quote:
      "I never thought I could lose 15kg while juggling work and kids. Coach Als made the meal plans so easy to follow, and the workouts fit my busy schedule perfectly. Best decision I ever made.",
  },
  {
    name: "James Reyes",
    job: "Office Employee",
    quote:
      "From 95kg to 72kg in 6 months. The keto meal plan was a game changer, and Coach Als was there every step of the way. I finally feel confident in my own body.",
  },
];
---

<!-- Testimonials Section Start -->
<section id="testimonials" class="our-testimonial-elite bg-section">
  <div class="container">
    <div class="row section-row">
      <div class="col-lg-12">
        <!-- Section Title Start -->
        <div class="section-title section-title-center">
          <h3 class="wow fadeInUp">Client Testimonials</h3>
          <h2 data-cursor="-opaque" class="text-anime-style-3">
            From all over the world, real people achieving real results with us
          </h2>
        </div>
        <!-- Section Title End -->
      </div>
    </div>

    <div class="row">
      <div class="col-xl-12">
        <!-- Testimonial Slider Start -->
        <div class="testimonial-slider-elite">
          <div class="swiper">
            <div data-cursor-text="Drag" class="swiper-wrapper">
              {
                testimonials.map((testimonial) => (
                  <div class="swiper-slide">
                    <div class="testimonial-item-elite testimonial-rating-box-royal">
                      <div class="testimonial-item-rating">
                        <i class="fa fa-solid fa-star" />
                        <i class="fa fa-solid fa-star" />
                        <i class="fa fa-solid fa-star" />
                        <i class="fa fa-solid fa-star" />
                        <i class="fa fa-solid fa-star" />
                      </div>
                      <div class="testimonial-item-body-elite">
                        <div class="testimonial-item-content-elite">
                          <h3 class="fst-italic">" {testimonial.quote} "</h3>
                        </div>
                        <div class="testimonial-item-footer-elite">
                          <div class="testimonial-author-content-elite">
                            <h3>{testimonial.name}</h3>
                            <p>{testimonial.job}</p>
                          </div>
                          <div class="testimonial-quote-elite">
                            <img src="/images/testimonial-quote.svg" alt="" />
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
        <!-- Testimonial Slider End -->
      </div>

      <div class="col-lg-12">
        <!-- Section Footer Text Start -->
        <div data-wow-delay="0.4s" class="section-footer-text section-satisfy-img wow fadeInUp">
          <p>Trusted by thousands of clients on their fitness journey worldwide.</p>
          <ul>
            <li><span class="counter">4.9</span>/5</li>
            <li>
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
              <i class="fa-solid fa-star"></i>
            </li>
            <li>Our 1000+ Reviews</li>
          </ul>
        </div>
        <!-- Section Footer Text End -->
      </div>
    </div>
  </div>
</section>
<!-- Testimonials Section End -->

---
import { Dumbbell, UtensilsCrossed } from "@lucide/astro/icons/index";

const services = [
  {
    title: "Online Coaching & Nutrition Guide",
    description:
      "A complete program to help you get fit, healthy, and confident. Easy-to-follow workouts you can do anytime, anywhere — no gym required. Includes a sustainable nutrition guide that teaches you what to eat, when to eat, and what to avoid, plus chat support throughout your transformation journey.",
    tag: "All Fitness Levels",
    icon: Dumbbell,
    delay: null,
  },
  {
    title: "Meal Plan Service",
    description:
      "High-protein, low-carb meals designed to balance hormones, not count calories. Seed-oil free and chef-prepared using premium ingredients like USDA Prime ribeye steak, fresh salmon, chicken, and fresh salads. Delivery available within Metro Manila.",
    tag: "Insulin Sensitivity Reset Diet",
    icon: UtensilsCrossed,
    delay: "0.2s",
  },
];

const footerTags = ["Weight Loss", "Body Transformation", "Custom Meal Plans", "Fitness Coaching"];
---

<section id="services" class="our-features-elite bg-section">
  <div class="container">
    <div class="row section-row">
      <div class="col-lg-12">
        <div class="section-title section-title-center">
          <h3 class="wow fadeInUp">Services</h3>
          <h2 data-cursor="-opaque" class="text-anime-style-3">
            Train anywhere with workouts and nutrition that fit your lifestyle
          </h2>
        </div>
      </div>
    </div>

    <div class="row justify-content-center">
      {
        services.map((service) => (
          <div class="col-xl-6 col-md-6">
            <div data-wow-delay={service.delay} class="features-item-elite wow fadeInUp">
              <div class="features-item-content-elite">
                <div class="features-item-header-elite">
                  <div class="features-item-title-elite">
                    <h3>{service.title}</h3>
                  </div>
                  <div class="icon-box">
                    <service.icon color="#FFFFFF" stroke-width="1.5" />
                  </div>
                </div>
                <div class="features-item-body-elite">
                  <p>{service.description}</p>
                </div>
              </div>
              <div class="features-item-tag-list-elite">
                <ul>
                  <li>{service.tag}</li>
                </ul>
              </div>
            </div>
          </div>
        ))
      }

      <div class="col-lg-12">
        <div data-wow-delay="0.4s" class="features-footer-elite wow fadeInUp">
          <div class="features-footer-list-elite">
            <ul>
              {footerTags.map((tag) => <li>{tag}</li>)}
            </ul>
          </div>
          <div class="section-footer-text">
            <p>
              Ready to start your transformation? <a href="#get-started" class="service-footer-text"
                >Book Free Consultation</a
              >
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

---
import { Dumbbell, Headset, LandPlot, MessagesSquare } from "@lucide/astro/icons/index";

const services = [
  {
    title: "Online Fitness Coaching",
    description:
      "Easy-to-follow workouts designed to help you use proper form, build confidence, and stay consistent. Each program is tailored to your lifestyle and goals.",
    tag: "All Fitness Levels",
    icon: Dumbbell,
    delay: null,
  },
  {
    title: "Personalized Nutrition Plan",
    description:
      "Learn what to eat, when to eat, and what to avoid while still enjoying your favorite foods — all guided by Coach Anton.",
    tag: "Flexible Eating",
    icon: LandPlot,
    delay: "0.2s",
  },
  {
    title: "Chat Support",
    description: "Share your meal photos and progress updates anytime, and we'll guide you every step of the way.",
    tag: "Real-Time Feedback",
    icon: MessagesSquare,
    delay: "0.4s",
  },
  {
    title: "Free Consultation",
    description:
      "Not sure where to start? Book a free consultation to understand the program and get all your questions answered.",
    tag: "Goal Assessment",
    icon: Headset,
    delay: "0.6s",
  },
];

const footerTags = ["Weight Loss", "Body Transformation", "Custom Meal Plans", "Fitness Coaching"];
---

<section id="services" class="our-features-elite bg-section">
  <div class="container">
    <div class="row section-row">
      <div class="col-lg-12">
        <div class="section-title section-title-center">
          <h3 class="wow fadeInUp">Services</h3>
          <h2 data-cursor="-opaque" class="text-anime-style-3">
            Train anywhere with workouts and nutrition that fit your lifestyle
          </h2>
        </div>
      </div>
    </div>

    <div class="row">
      {
        services.map((service) => (
          <div class="col-xl-3 col-md-6">
            <div data-wow-delay={service.delay} class="features-item-elite wow fadeInUp">
              <div class="features-item-content-elite">
                <div class="features-item-header-elite">
                  <div class="features-item-title-elite">
                    <h3>{service.title}</h3>
                  </div>
                  <div class="icon-box">
                    <service.icon color="#FFFFFF" stroke-width="1.5" />
                  </div>
                </div>
                <div class="features-item-body-elite">
                  <p>{service.description}</p>
                </div>
              </div>
              <div class="features-item-tag-list-elite">
                <ul>
                  <li>{service.tag}</li>
                </ul>
              </div>
            </div>
          </div>
        ))
      }

      <div class="col-lg-12">
        <div data-wow-delay="0.4s" class="features-footer-elite wow fadeInUp">
          <div class="features-footer-list-elite">
            <ul>
              {footerTags.map((tag) => <li>{tag}</li>)}
            </ul>
          </div>
          <div class="section-footer-text">
            <p>
              Ready to start your transformation? <a href="#get-started" class="service-footer-text"
                >Book Free Consultation</a
              >
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
